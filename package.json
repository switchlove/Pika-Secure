{
  "name": "pikasecure",
  "version": "0.1.0",
  "private": true,
  "description": "Discord verification/security bot: quarantine-gated joins with risk-based captcha escalation.",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy-commands": "node src/deploy-commands.js",
    "deploy-commands:global": "node src/deploy-commands.js --global",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "audit-ci --config .audit-ci.json"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "discord.js": "^14.26.5",
    "dotenv": "^17.4.2"
  },
  "optionalDependencies": {
    "@napi-rs/canvas-win32-x64-msvc": "^1.0.2",
    "@rolldown/binding-win32-x64-msvc": "^1.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "audit-ci": "^7.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  }
}
