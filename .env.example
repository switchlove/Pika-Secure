# Discord bot credentials — from the Developer Portal (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Dev guild for instant (guild-scoped) slash command registration.
# Not used for feature config — per-guild settings live in SQLite via /setup.
DISCORD_GUILD_ID=

# Optional override; defaults to ./data/pikasecure.sqlite
DATABASE_PATH=./data/pikasecure.sqlite

# Optional: minimum level printed to the console — one of error, warn, info (default: info).
LOG_LEVEL=info

# Optional: if set, warn/error log lines are also appended to a daily-rotating file under this
# directory (in addition to the console output you always get). Unset by default.
LOG_DIR=
